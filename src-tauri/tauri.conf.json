{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MusicPlayer",
  "version": "0.2.0",
  "identifier": "com.forclaude.musicplayer",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Music Player",
        "width": 1100,
        "height": 720,
        "minWidth": 820,
        "minHeight": 560
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.png"
    ]
  }
}
