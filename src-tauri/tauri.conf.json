{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MusicPlayer",
  "version": "0.21.0",
  "identifier": "com.indernol.musicplayer",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Music Player",
        "width": 1100,
        "height": 720,
        "minWidth": 820,
        "minHeight": 560
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "android": {
      "minSdkVersion": 28
    },
    "publisher": "Indernol",
    "homepage": "https://github.com/Indernol/music-player",
    "category": "Music",
    "shortDescription": "Local-first music player with YouTube search, streaming and downloads.",
    "longDescription": "A native local-first music player: scan local folders, search and stream from YouTube (yt-dlp), download tracks as mp3, and manage playlists with custom covers. Includes MPRIS and Discord Rich Presence.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      }
    }
  }
}
